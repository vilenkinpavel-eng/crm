{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=31536000; includeSubDomains"
        }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/(.*)",
      "has": [{"type": "header", "key": "x-forwarded-proto", "value": "http"}],
      "destination": "https://connected-agency.com/$1",
      "permanent": true
    },
    {
      "source": "/crm",
      "destination": "/os",
      "permanent": true
    }
  ],
  "rewrites": [
    { "source": "/os", "destination": "/index.html" },
    { "source": "/os/(.*)", "destination": "/index.html" }
  ]
}
